{
  "FileStorage": {
    "RootPath": "Uploads",
    "MaxFileSizeInMB": 10,
    "AllowedExtensions": [".pdf", ".doc", ".docx", ".zip"]
  },
  "Jwt": {
    "Issuer": "TraineeManagementApi",
    "Audience": "TraineeManagementClient",
    "ExpiryMinutes": 60,
    "Key": "ThisIsVerySecureSecretKeyForJwtTokenGeneration"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
